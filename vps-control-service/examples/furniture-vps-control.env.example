# Required: bearer token for API authentication
VPS_CONTROL_TOKEN=change-me-to-a-random-secret

# Network
VPS_CONTROL_HOST=127.0.0.1
VPS_CONTROL_PORT=8789

# Default webserver (nginx or caddy)
VPS_CONTROL_WEBSERVER=nginx

# Directories
VPS_CONTROL_SITES_DIR=/srv/sites
VPS_CONTROL_STAGING_DIR=/srv/deploy-staging
VPS_CONTROL_LOG_DIR=/var/log/furniture-control
VPS_CONTROL_MAX_BODY_BYTES=262144

# Comma-separated list of allowed source hosts for deploy artifacts.
# Include the Cloudflare Pages host used by PUBLIC_APP_ORIGIN.
VPS_CONTROL_ALLOWED_SOURCE_HOSTS=furniture-orders-mvp.pages.dev,github.com,raw.githubusercontent.com,example.com
