# Select one supported provider:
# openai | groq | gemini | openrouter | nvidia
AI_PROVIDER=openai

# Optional. Leave empty to use the selected provider's default model.
AI_MODEL=

# Configure only the key for the selected provider.
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

# Manual reply suggestions only. Does not send messages.
AI_COMMUNICATIONS_ENABLED=false

# Manual OCR/vision recognition. Keep false until local synthetic smoke succeeds.
OCR_RECOGNITION_ENABLED=false
OCR_PROVIDER=openai
OCR_MODEL=gpt-4o-mini

# Keep false until migration 0019, consent policy, retention, and OCR_MEDIA_BUCKET are approved.
OCR_CUSTOMER_IMAGES_ENABLED=false

# Twenty CRM remains disabled until a workspace API contract is verified.
TWENTY_API_BASE_URL=
TWENTY_API_KEY=
TWENTY_WORKSPACE_ID=
TWENTY_SYNC_ENABLED=false

# Portfolio media uploads. R2 binding is configured in Cloudflare Pages/Wrangler,
# not as a text secret. Leave public URL empty to use /media/<storage-key>.
PORTFOLIO_MEDIA_PUBLIC_BASE_URL=

# Optional local variables for explicit production smoke checks.
# Never commit real tokens in .env or .dev.vars.
PROPOSAL_SMOKE_BASE_URL=
PROPOSAL_SMOKE_ADMIN_TOKEN=
PROPOSAL_SMOKE_ORDER_ID=
PORTFOLIO_SMOKE_BASE_URL=
PORTFOLIO_SMOKE_ADMIN_TOKEN=
PORTFOLIO_SMOKE_IMAGE=
PORTFOLIO_SMOKE_PUBLISH=false
