# Select one supported provider:
# openai | groq | gemini | openrouter | nvidia
AI_PROVIDER=openai

# Optional. Leave empty to use the selected provider's default model.
AI_MODEL=

# Configure only the key for the selected provider.
OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
NVIDIA_API_KEY=

# Manual reply suggestions only. Does not send messages.
AI_COMMUNICATIONS_ENABLED=false

# Manual OCR/vision recognition. Keep false until local synthetic smoke succeeds.
OCR_RECOGNITION_ENABLED=false
OCR_PROVIDER=openai
OCR_MODEL=gpt-4o-mini

# Twenty CRM remains disabled until a workspace API contract is verified.
TWENTY_API_BASE_URL=
TWENTY_API_KEY=
TWENTY_WORKSPACE_ID=
TWENTY_SYNC_ENABLED=false
